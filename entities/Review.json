{
  "name": "Review",
  "type": "object",
  "properties": {
    "seller_id": {
      "type": "string",
      "description": "Seller being reviewed"
    },
    "reviewer_id": {
      "type": "string"
    },
    "reviewer_name": {
      "type": "string"
    },
    "reviewer_avatar": {
      "type": "string"
    },
    "rating_stars": {
      "type": "number",
      "description": "1-5 stars"
    },
    "justification_text": {
      "type": "string",
      "description": "Review text"
    }
  },
  "required": [
    "seller_id",
    "reviewer_id",
    "rating_stars",
    "justification_text"
  ],
  "rls": {
    "create": {
      "data.reviewer_id": "{{user.id}}"
    },
    "read": {},
    "update": {
      "$or": [
        {
          "data.reviewer_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.reviewer_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}