{
  "name": "Profile",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "description": "Unique username"
    },
    "full_name": {
      "type": "string",
      "description": "Full display name"
    },
    "phone_number": {
      "type": "string",
      "description": "Phone number"
    },
    "bio": {
      "type": "string",
      "description": "Short bio"
    },
    "avatar_url": {
      "type": "string",
      "description": "Profile picture URL"
    },
    "trust_score": {
      "type": "number",
      "default": 50,
      "description": "Trust score 0-100"
    },
    "seller_rating": {
      "type": "number",
      "default": 0,
      "description": "Average seller rating"
    },
    "listings_count": {
      "type": "number",
      "default": 0
    },
    "sales_count": {
      "type": "number",
      "default": 0
    },
    "verified_sales_count": {
      "type": "number",
      "default": 0
    },
    "is_verified_badge": {
      "type": "boolean",
      "default": false
    },
    "is_pro_seller": {
      "type": "boolean",
      "default": false
    },
    "is_banned": {
      "type": "boolean",
      "default": false
    },
    "username_change_count": {
      "type": "number",
      "default": 0
    },
    "is_online": {
      "type": "boolean",
      "default": false
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "location_text": {
      "type": "string",
      "description": "Public location"
    },
    "onboarding_complete": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "username",
    "full_name",
    "phone_number"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {},
    "update": {},
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}