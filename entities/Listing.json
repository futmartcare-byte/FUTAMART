{
  "name": "Listing",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Listing title"
    },
    "description": {
      "type": "string",
      "description": "Listing description"
    },
    "price": {
      "type": "number",
      "description": "Price"
    },
    "category": {
      "type": "string",
      "enum": [
        "electronics",
        "vehicles",
        "fashion",
        "home_garden",
        "sports",
        "books",
        "toys",
        "services",
        "other"
      ],
      "description": "Category"
    },
    "condition": {
      "type": "string",
      "enum": [
        "new",
        "used"
      ],
      "description": "Item condition"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Image URLs (3-15)"
    },
    "location_text": {
      "type": "string",
      "description": "Location"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "sold"
      ],
      "default": "active"
    },
    "view_count": {
      "type": "number",
      "default": 0
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "is_sponsored": {
      "type": "boolean",
      "default": false
    },
    "edit_history_count": {
      "type": "number",
      "default": 0
    },
    "seller_username": {
      "type": "string"
    },
    "seller_avatar": {
      "type": "string"
    },
    "seller_is_pro": {
      "type": "boolean",
      "default": false
    },
    "seller_is_verified": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title",
    "description",
    "price",
    "category",
    "condition",
    "images",
    "location_text"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "data.status": "active"
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}