{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Recipient user ID"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "info",
        "report",
        "admin",
        "listing_rejected",
        "message",
        "marketplace",
        "promotions",
        "safety_alert",
        "system_update"
      ],
      "default": "info"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "string",
      "description": "Optional deep link"
    },
    "from_name": {
      "type": "string"
    },
    "image_url": {
      "type": "string",
      "description": "Optional notification image"
    },
    "category": {
      "type": "string",
      "enum": [
        "admin",
        "marketplace",
        "promotions",
        "safety_alerts",
        "system_updates"
      ],
      "default": "admin"
    }
  },
  "required": [
    "user_id",
    "title",
    "message"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "data.user_id": "{{user.id}}"
    },
    "update": {
      "data.user_id": "{{user.id}}"
    },
    "delete": {
      "data.user_id": "{{user.id}}"
    }
  }
}